{
  "name": "eudi-verify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run && pnpm --filter @eudi-verify/embed test",
    "test:unit": "vitest run",
    "lint:api": "spectral lint openapi/eudi-verifier.yaml",
    "build": "pnpm -r build",
    "verify": "bash scripts/ci.sh",
    "hooks:install": "bash scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@stoplight/spectral-cli": "^6.16.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  }
}
