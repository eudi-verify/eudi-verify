#!/usr/bin/env bash
# Installed by: pnpm hooks:install
# Format staged files before commit — full CI still runs on pre-push.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
# shellcheck disable=SC1091
source "$ROOT/scripts/ensure-node.sh"
cd "$ROOT"

STAGED=()
while IFS= read -r -d '' file; do
  STAGED+=("$file")
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

if ((${#STAGED[@]} == 0)); then
  exit 0
fi

echo "Formatting staged files (prettier)..."
pnpm exec prettier --write --ignore-unknown "${STAGED[@]}"
git add -- "${STAGED[@]}"
