{
  "name": "@eudi-verify/client",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "pnpm build && gzip -c dist/index.js | wc -c"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
