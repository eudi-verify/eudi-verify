{
  "name": "@eudi-verify/client",
  "version": "1.3.0",
  "description": "Typed API client and state machine for EUDI Wallet verification",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "sync:version": "node ../../scripts/generate-package-versions.mjs client",
    "build": "node ../../scripts/generate-package-versions.mjs client && tsup src/index.ts --format esm --dts --clean",
    "typecheck": "node ../../scripts/generate-package-versions.mjs client && tsc --noEmit",
    "test": "node ../../scripts/generate-package-versions.mjs client && vitest run",
    "size": "pnpm build && gzip -c dist/index.js | wc -c",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "eudi",
    "wallet",
    "verifier",
    "openid4vp",
    "eu-digital-identity",
    "client",
    "api-client"
  ],
  "author": "eudi-verify contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eudi-verify/eudi-verify.git",
    "directory": "packages/client"
  },
  "dependencies": {
    "qrcode": "1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "jsqr": "1.4.0",
    "tsup": "^8.0.0"
  }
}
